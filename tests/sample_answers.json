{
  "target.tools": ["Claude Code", "Codex", "Cursor"],
  "project.name": "payments-api",
  "project.description": "결제 승인/정산을 담당하는 내부 API 서비스",
  "project.language": "Python",
  "project.language_version": "Python 3.12",
  "project.framework": "FastAPI",
  "project.package_manager": "uv",
  "profile.role": "backend",
  "profile.expertise": "시니어",
  "dev.install_cmd": "uv sync",
  "dev.test_cmd": "uv run pytest",
  "dev.lint_cmd": "uv run ruff check .",
  "dev.format_cmd": "uv run ruff format .",
  "dev.run_cmd": "uv run uvicorn app.main:app --reload",
  "dev.never_touch": [".env", "secrets/", "migrations/legacy/"],
  "dev.architecture_layers": "domain -> application -> infrastructure -> api",
  "dev.code_style_notes": "엔티티는 기본 lazy loading. 예외는 도메인 예외 계층으로만 던진다.",
  "gh.default_branch": "main",
  "gh.commit_convention": "Conventional Commits",
  "gh.commit_language": "한국어",
  "gh.branch_naming": "feature/<issue>-<slug>",
  "docs.language": "한국어",
  "docs.tone": "간결하게",
  "docs.primary_format": "Markdown",
  "mcp.servers": ["github", "fetch", "sequential-thinking"],
  "mcp.tokens": { "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_example_token_123" }
}
